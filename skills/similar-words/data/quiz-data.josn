  "grammar": {
    "name": "Grammar",
    "purpose": "how does the language actually work?",
    "functions": {
      "reported_speech": {
        "label": "Reported Speech",
        "when": "reporting what someone else said",
        "questions": [
          {
            "q": "Direct: 'I am tired,' she said. Reported: She said (that) ___.",
            "options": [
              "she is tired",
              "she was tired",
              "she has been tired",
              "she tired"
            ],
            "correct": 1,
            "explain": "Reported speech usually shifts the tense back one step: am → was."
          },
          {
            "q": "Direct: 'I will call you,' he said. Reported: He said (that) ___.",
            "options": [
              "he will call me",
              "he would call me",
              "he calls me",
              "he is calling me"
            ],
            "correct": 1,
            "explain": "Will shifts back to would when reporting in the past."
          },
          {
            "q": "Direct: 'Where do you live?' she asked. Reported: She asked ___.",
            "options": [
              "where do I live",
              "where did I live",
              "where I lived",
              "where I live"
            ],
            "correct": 2,
            "explain": "Reported questions drop the auxiliary and use normal word order, with the tense shifted back."
          },
          {
            "q": "Direct: 'Close the door,' he said. Reported: He told me ___.",
            "options": [
              "close the door",
              "to close the door",
              "closing the door",
              "that close the door"
            ],
            "correct": 1,
            "explain": "Reported commands use told/asked + object + infinitive with 'to'."
          },
          {
            "q": "Which time expression changes to 'the next day' in reported speech?",
            "options": [
              "yesterday",
              "tomorrow",
              "now",
              "ago"
            ],
            "correct": 1,
            "explain": "'Tomorrow' commonly shifts to 'the next day' (or 'the following day') when reporting."
          }
        ]
      },
      "passive": {
        "label": "Passive Voice",
        "when": "when the action matters more than the doer",
        "questions": [
          {
            "q": "Active: 'They built the bridge in 1990.' Passive: ___.",
            "options": [
              "The bridge built in 1990.",
              "The bridge was built in 1990.",
              "The bridge is built in 1990.",
              "The bridge has built in 1990."
            ],
            "correct": 1,
            "explain": "Past simple passive: was/were + past participle."
          },
          {
            "q": "Which is the correct present simple passive pattern?",
            "options": [
              "was + past participle",
              "is/are + past participle",
              "has + past participle",
              "be + -ing"
            ],
            "correct": 1,
            "explain": "Present simple passive: am/is/are + past participle."
          },
          {
            "q": "Active: 'Someone has stolen my bike.' Passive: ___.",
            "options": [
              "My bike stole.",
              "My bike was stolen.",
              "My bike has been stolen.",
              "My bike is stolen."
            ],
            "correct": 2,
            "explain": "Present perfect passive: has/have been + past participle."
          },
          {
            "q": "Passive voice is most often used when ___.",
            "options": [
              "the action matters more than who did it",
              "we want to sound very direct",
              "we're speaking casually",
              "the subject is always a person"
            ],
            "correct": 0,
            "explain": "We use the passive to focus on the action or result rather than the agent."
          },
          {
            "q": "Choose the correct passive for 'People speak English here.'",
            "options": [
              "English speaks here.",
              "English is spoken here.",
              "English was spoken here.",
              "English has spoken here."
            ],
            "correct": 1,
            "explain": "Present simple passive of 'speak' is 'is spoken'."
          }
        ]
      },
      "gerund_infinitive": {
        "label": "Gerund & Infinitive",
        "when": "-ing forms vs. to + verb",
        "questions": [
          {
            "q": "I enjoy ___ music.",
            "options": [
              "to listen",
              "listening",
              "listen",
              "listened"
            ],
            "correct": 1,
            "explain": "'Enjoy' is always followed by a gerund (-ing form)."
          },
          {
            "q": "She decided ___ early.",
            "options": [
              "leaving",
              "leave",
              "to leave",
              "left"
            ],
            "correct": 2,
            "explain": "'Decide' is followed by a to-infinitive."
          },
          {
            "q": "They avoid ___ junk food.",
            "options": [
              "to eat",
              "eating",
              "eat",
              "ate"
            ],
            "correct": 1,
            "explain": "'Avoid' is followed by a gerund."
          },
          {
            "q": "He wants ___ a new car.",
            "options": [
              "buying",
              "to buy",
              "buy",
              "bought"
            ],
            "correct": 1,
            "explain": "'Want' is followed by a to-infinitive."
          },
          {
            "q": "Which verb is normally followed by a gerund, not an infinitive?",
            "options": [
              "want",
              "decide",
              "suggest",
              "hope"
            ],
            "correct": 2,
            "explain": "'Suggest' takes a gerund: 'I suggest going now', not 'I suggest to go'."
          }
        ]
      },
      "comparative": {
        "label": "Comparative & Superlative",
        "when": "comparing two or more things",
        "questions": [
          {
            "q": "This book is ___ than the last one.",
            "options": [
              "interesting",
              "more interesting",
              "most interesting",
              "interestinger"
            ],
            "correct": 1,
            "explain": "Longer adjectives form the comparative with 'more', not an -er ending."
          },
          {
            "q": "She is the ___ student in the class.",
            "options": [
              "smart",
              "smarter",
              "smartest",
              "more smart"
            ],
            "correct": 2,
            "explain": "Superlatives (the -est form) compare one thing against a whole group."
          },
          {
            "q": "Choose the correct comparative of 'good'.",
            "options": [
              "gooder",
              "more good",
              "better",
              "best"
            ],
            "correct": 2,
            "explain": "'Good' is irregular: good → better → best."
          },
          {
            "q": "London is ___ than Manchester in terms of population.",
            "options": [
              "big",
              "bigger",
              "biggest",
              "more big"
            ],
            "correct": 1,
            "explain": "Short adjectives like 'big' take -er in the comparative (with the consonant doubled)."
          },
          {
            "q": "Which pattern means 'the more you practise, the better you get'?",
            "options": [
              "comparative + comparative",
              "superlative + superlative",
              "as...as",
              "than-clause"
            ],
            "correct": 0,
            "explain": "The double comparative pattern (the + comparative, the + comparative) links two increasing things."
          }
        ]
      },
      "inversion": {
        "label": "Inversion",
        "when": "flipping subject and verb for emphasis",
        "questions": [
          {
            "q": "Never ___ such a beautiful sunset.",
            "options": [
              "I have seen",
              "have I seen",
              "I saw",
              "did I saw"
            ],
            "correct": 1,
            "explain": "After a negative adverbial like 'never' at the start, the subject and auxiliary invert."
          },
          {
            "q": "Which sentence uses inversion correctly?",
            "options": [
              "Rarely I have seen such dedication.",
              "Rarely have I seen such dedication.",
              "Rarely I saw such dedication.",
              "Rarely did I have seen such dedication."
            ],
            "correct": 1,
            "explain": "'Rarely' at the start of a sentence triggers subject-auxiliary inversion."
          },
          {
            "q": "Not only ___ late, but she also forgot her bag.",
            "options": [
              "she was",
              "was she",
              "she is",
              "is she"
            ],
            "correct": 1,
            "explain": "'Not only' at the start of a clause requires inversion: was she."
          },
          {
            "q": "Inversion after negative adverbials (never, rarely, seldom) is mostly used in ___ English.",
            "options": [
              "casual spoken",
              "formal written",
              "text messages",
              "slang"
            ],
            "correct": 1,
            "explain": "This structure adds emphasis and is typically found in more formal, written English."
          },
          {
            "q": "___ you need help, just call me.",
            "options": [
              "If",
              "Should",
              "When",
              "Because"
            ],
            "correct": 1,
            "explain": "'Should' can replace 'if' with inversion: 'Should you need help' = 'If you should need help'."
          }
        ]
      },
      "linking_cleft": {
        "label": "Linking Words & Cleft Sentences",
        "when": "connecting ideas, and using it/what/all for emphasis",
        "questions": [
          {
            "q": "She was tired; ___, she kept working.",
            "options": [
              "therefore",
              "nevertheless",
              "moreover",
              "because"
            ],
            "correct": 1,
            "explain": "'Nevertheless' links a contrasting idea, showing she worked despite being tired."
          },
          {
            "q": "He missed the bus ___ he woke up late.",
            "options": [
              "although",
              "because",
              "however",
              "whereas"
            ],
            "correct": 1,
            "explain": "'Because' introduces the reason for an action."
          },
          {
            "q": "___ the rain, we went for a walk.",
            "options": [
              "Despite",
              "Although",
              "Because",
              "Since"
            ],
            "correct": 0,
            "explain": "'Despite' is followed directly by a noun phrase, unlike 'although', which needs a clause."
          },
          {
            "q": "Choose the correct it-cleft sentence.",
            "options": [
              "It was Maria who solved the problem.",
              "What was Maria who solved the problem.",
              "All was Maria who solved the problem.",
              "This was Maria who solved the problem."
            ],
            "correct": 0,
            "explain": "An it-cleft (It + be + ...) puts special emphasis on 'Maria' as the one who acted."
          },
          {
            "q": "___ I need is a good night's sleep.",
            "options": [
              "It",
              "What",
              "Which",
              "That"
            ],
            "correct": 1,
            "explain": "A what-cleft ('What I need is...') emphasises the thing being talked about."
          }
        ]
      }
    }
  },
  "vocabulary": {
    "name": "Vocabulary",
    "purpose": "which word actually fits?",
    "functions": {
      "prepositions": {
        "label": "Prepositions",
        "when": "the small words that link ideas",
        "questions": [
          {
            "q": "She's been working here ___ 2019.",
            "options": [
              "since",
              "for",
              "from",
              "at"
            ],
            "correct": 0,
            "explain": "'Since' is used with a specific starting point in time."
          },
          {
            "q": "The keys are ___ the table.",
            "options": [
              "in",
              "on",
              "at",
              "into"
            ],
            "correct": 1,
            "explain": "'On' is used for a surface, like a table."
          },
          {
            "q": "We arrived ___ the airport an hour early.",
            "options": [
              "in",
              "on",
              "at",
              "to"
            ],
            "correct": 2,
            "explain": "'At' is used for a specific point or place, such as an airport."
          },
          {
            "q": "He's afraid ___ spiders.",
            "options": [
              "from",
              "of",
              "for",
              "with"
            ],
            "correct": 1,
            "explain": "'Afraid' is followed by 'of'."
          },
          {
            "q": "The cat jumped ___ the fence.",
            "options": [
              "over",
              "on",
              "at",
              "in"
            ],
            "correct": 0,
            "explain": "'Over' describes movement across and above an obstacle like a fence."
          }
        ]
      },
      "similar_words": {
        "label": "Similar Words",
        "when": "near-synonyms with different shades of meaning",
        "questions": [
          {
            "q": "Which word means 'to look at something quickly'?",
            "options": [
              "gaze",
              "glance",
              "stare",
              "gawk"
            ],
            "correct": 1,
            "explain": "'Glance' means a brief, quick look, unlike 'stare' or 'gaze', which are longer."
          },
          {
            "q": "Choose the best word: 'The lecture was so ___ that half the class fell asleep.'",
            "options": [
              "interesting",
              "tedious",
              "thrilling",
              "brief"
            ],
            "correct": 1,
            "explain": "'Tedious' specifically implies long and boring, fitting the context."
          },
          {
            "q": "'Economical' most precisely means ___.",
            "options": [
              "cheap in price",
              "careful with money and resources",
              "free of charge",
              "wealthy"
            ],
            "correct": 1,
            "explain": "'Economical' describes efficient use of money or resources, not simply a low price."
          },
          {
            "q": "Which word suggests a stronger, more sudden fear than 'worried'?",
            "options": [
              "concerned",
              "anxious",
              "terrified",
              "uneasy"
            ],
            "correct": 2,
            "explain": "'Terrified' implies intense, often sudden fear, much stronger than 'worried' or 'uneasy'."
          },
          {
            "q": "Which word means 'important or likely to be remembered in history'?",
            "options": [
              "historical",
              "historic",
              "ancient",
              "former"
            ],
            "correct": 1,
            "explain": "'Historic' means significant in history; 'historical' just means relating to history in general."
          }
        ]
      },
      "collocations": {
        "label": "Collocations",
        "when": "words that naturally go together",
        "questions": [
          {
            "q": "Which verb collocates with 'a decision'?",
            "options": [
              "do",
              "make",
              "take",
              "have"
            ],
            "correct": 1,
            "explain": "We 'make' a decision, not 'do' or 'take' one."
          },
          {
            "q": "Which verb collocates with 'a mistake'?",
            "options": [
              "do",
              "make",
              "take",
              "give"
            ],
            "correct": 1,
            "explain": "We 'make' a mistake."
          },
          {
            "q": "Which verb collocates with 'homework'?",
            "options": [
              "make",
              "do",
              "take",
              "have"
            ],
            "correct": 1,
            "explain": "We 'do' homework, unlike 'make', which pairs with things we create."
          },
          {
            "q": "Which noun does NOT typically collocate with 'heavy'?",
            "options": [
              "heavy rain",
              "heavy traffic",
              "heavy sunshine",
              "heavy smoker"
            ],
            "correct": 2,
            "explain": "'Heavy' collocates with rain, traffic, and smokers, but not naturally with 'sunshine'."
          },
          {
            "q": "Which verb collocates with 'attention'?",
            "options": [
              "pay",
              "make",
              "do",
              "take"
            ],
            "correct": 0,
            "explain": "We 'pay' attention to something."
          }
        ]
      },
      "descriptive_verbs": {
        "label": "Descriptive Verbs",
        "when": "vivid verbs instead of generic ones",
        "questions": [
          {
            "q": "Which verb is a more descriptive alternative to 'walked', meaning to move slowly and wearily?",
            "options": [
              "strolled",
              "trudged",
              "dashed",
              "skipped"
            ],
            "correct": 1,
            "explain": "'Trudged' vividly suggests slow, heavy, tired walking."
          },
          {
            "q": "Which verb means 'to speak in a complaining, unhappy way'?",
            "options": [
              "whispered",
              "mumbled",
              "whined",
              "announced"
            ],
            "correct": 2,
            "explain": "'Whined' describes a complaining, high-pitched way of speaking."
          },
          {
            "q": "Which verb best replaces 'looked' to mean 'stared angrily'?",
            "options": [
              "glanced",
              "glared",
              "peeked",
              "observed"
            ],
            "correct": 1,
            "explain": "'Glared' specifically means to look at someone with anger."
          },
          {
            "q": "Which verb means 'to eat quickly and greedily'?",
            "options": [
              "nibbled",
              "devoured",
              "sipped",
              "tasted"
            ],
            "correct": 1,
            "explain": "'Devoured' means to eat something fast and hungrily."
          },
          {
            "q": "Which verb best replaces 'said' to mean 'said something quietly and hesitantly'?",
            "options": [
              "shouted",
              "murmured",
              "declared",
              "announced"
            ],
            "correct": 1,
            "explain": "'Murmured' describes speaking softly and indistinctly."
          }
        ]
      },
      "news": {
        "label": "News",
        "when": "vocabulary around journalism and current events",
        "questions": [
