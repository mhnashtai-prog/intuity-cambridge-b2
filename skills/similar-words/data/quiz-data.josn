              "headline",
              "caption",
              "editorial"
            ],
            "correct": 1,
            "explain": "The 'headline' is the large title text introducing a news story."
          },
          {
            "q": "A person who writes news articles is called a ___.",
            "options": [
              "publisher",
              "journalist",
              "editor",
              "broadcaster"
            ],
            "correct": 1,
            "explain": "A 'journalist' is someone who researches and writes news stories."
          },
          {
            "q": "Which word describes a news story that has not yet been confirmed?",
            "options": [
              "verified",
              "unconfirmed",
              "breaking",
              "exclusive"
            ],
            "correct": 1,
            "explain": "'Unconfirmed' means the information hasn't been officially verified yet."
          },
          {
            "q": "The section of a newspaper giving the writer's opinion is called the ___.",
            "options": [
              "headline",
              "editorial",
              "obituary",
              "classifieds"
            ],
            "correct": 1,
            "explain": "An 'editorial' is an article expressing the opinion of the publication."
          },
          {
            "q": "'Breaking news' refers to ___.",
            "options": [
              "old news",
              "news that just happened",
              "fake news",
              "local news"
            ],
            "correct": 1,
            "explain": "'Breaking news' describes an important story that is developing right now."
          }
        ]
      }
    }
  }
