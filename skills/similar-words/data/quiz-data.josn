{
  "tenses": {
    "name": "Tenses",
    "purpose": "when do things happen?",
    "functions": {
      "present": {
        "label": "Present",
        "when": "now, habits, and facts",
        "questions": [
          {
            "q": "Choose the correct present simple sentence.",
            "options": [
              "She go to school every day.",
              "She goes to school every day.",
              "She going to school every day.",
              "She is go to school every day."
            ],
            "correct": 1,
            "explain": "Present simple with a third-person singular subject (she) needs the -s ending: goes."
          },
          {
            "q": "What are you doing right now?",
            "options": [
              "I do my homework.",
              "I'm doing my homework.",
              "I did my homework.",
              "I have done my homework."
            ],
            "correct": 1,
            "explain": "Present continuous (am/is/are + -ing) describes an action happening at this moment."
          },
          {
            "q": "Choose the correct present perfect sentence.",
            "options": [
              "I have seen that film twice.",
              "I saw seen that film twice.",
              "I have see that film twice.",
              "I has seen that film twice."
            ],
            "correct": 0,
            "explain": "Present perfect = have/has + past participle. First person uses 'have', not 'has'."
          },
          {
            "q": "She ___ English for three years.",
            "options": [
              "has been studying",
              "have been studying",
              "is studying",
              "has study"
            ],
            "correct": 0,
            "explain": "Present perfect continuous = has/have been + -ing, for an action continuing up to now."
          },
          {
            "q": "Which time expression usually goes with the present perfect?",
            "options": [
              "yesterday",
              "last week",
              "already",
              "next month"
            ],
            "correct": 2,
            "explain": "'Already' is a classic present-perfect signal word; the others point to a finished or future time."
          }
        ]
      },
      "past": {
        "label": "Past",
        "when": "completed or ongoing past actions",
        "questions": [
          {
            "q": "They ___ to the cinema last night.",
            "options": [
              "go",
              "goes",
              "went",
              "have gone"
            ],
            "correct": 2,
            "explain": "Past simple for a finished action at a stated past time (last night)."
          },
          {
            "q": "I ___ dinner when the phone rang.",
            "options": [
              "cooked",
              "was cooking",
              "cook",
              "have cooked"
            ],
            "correct": 1,
            "explain": "Past continuous (was/were + -ing) sets the scene for an action interrupted by another."
          },
          {
            "q": "By the time we arrived, the film ___.",
            "options": [
              "already started",
              "had already started",
              "has already started",
              "was already starting"
            ],
            "correct": 1,
            "explain": "Past perfect (had + past participle) shows one past action happened before another."
          },
          {
            "q": "She was tired because she ___ all day.",
            "options": [
              "had been working",
              "was working",
              "has worked",
              "worked"
            ],
            "correct": 0,
            "explain": "Past perfect continuous (had been + -ing) explains the cause of a later past state."
          },
          {
            "q": "Which word usually signals the past perfect?",
            "options": [
              "yesterday",
              "by the time",
              "now",
              "tomorrow"
            ],
            "correct": 1,
            "explain": "'By the time' compares two past events, which is exactly what the past perfect is for."
          }
        ]
      },
      "future": {
        "label": "Future",
        "when": "plans, predictions, and certainty",
        "questions": [
          {
            "q": "I think it ___ rain later.",
            "options": [
              "will",
              "is going to",
              "is",
              "would"
            ],
            "correct": 0,
            "explain": "'Will' is used for spontaneous predictions and opinions about the future."
          },
          {
            "q": "We ___ visit my grandmother this weekend — we've already decided.",
            "options": [
              "will",
              "are going to",
              "are",
              "would"
            ],
            "correct": 1,
            "explain": "'Going to' expresses a plan or intention decided before the moment of speaking."
          },
          {
            "q": "I ___ my dentist at 4pm tomorrow.",
            "options": [
              "see",
              "will see",
              "am seeing",
              "am going to seeing"
            ],
            "correct": 2,
            "explain": "Present continuous is used for fixed, pre-arranged future plans."
          },
          {
            "q": "The train ___ at 9am tomorrow.",
            "options": [
              "leaves",
              "is leaving",
              "will leave",
              "is going to leave"
            ],
            "correct": 0,
            "explain": "Present simple is used for timetables and schedules, even future ones."
          },
          {
            "q": "This time tomorrow, I ___ on a plane to Rome.",
            "options": [
              "will fly",
              "will be flying",
              "am flying",
              "fly"
            ],
            "correct": 1,
            "explain": "Future continuous (will be + -ing) describes an action in progress at a specific future moment."
          },
          {
            "q": "By 2030, scientists ___ a cure.",
            "options": [
              "will find",
              "will have found",
              "find",
              "are finding"
            ],
            "correct": 1,
            "explain": "Future perfect (will have + past participle) describes something completed before a future point."
          }
        ]
      },
      "present_modals": {
        "label": "Present Modals",
        "when": "ability, obligation, and possibility now",
        "questions": [
          {
            "q": "You ___ wear a seatbelt in this country — it's the law.",
            "options": [
              "might",
              "must",
              "could",
              "would"
            ],
            "correct": 1,
            "explain": "'Must' expresses strong obligation, especially rules and laws."
          },
          {
            "q": "She ___ speak three languages fluently.",
            "options": [
              "must",
              "should",
              "can",
              "might"
            ],
            "correct": 2,
            "explain": "'Can' expresses present ability."
          },
          {
            "q": "It ___ rain later — the sky looks grey.",
            "options": [
              "must",
              "might",
              "should",
              "has to"
            ],
            "correct": 1,
            "explain": "'Might' expresses a present possibility, not a certainty."
          },
          {
            "q": "You ___ see a doctor about that cough.",
            "options": [
              "should",
              "can",
              "must",
              "will"
            ],
            "correct": 0,
            "explain": "'Should' is used to give advice."
          },
          {
            "q": "He isn't answering his phone — he ___ be asleep.",
            "options": [
              "can",
              "must",
              "should",
              "would"
            ],
            "correct": 1,
            "explain": "'Must' expresses a confident logical deduction about the present."
          }
        ]
      },
      "past_modals": {
        "label": "Past Modals",
        "when": "deduction, regret, and unreal past possibility",
        "questions": [
          {
            "q": "She ___ forgotten her phone — it isn't in her bag.",
            "options": [
              "must have",
              "should have",
              "can have",
              "would have"
            ],
            "correct": 0,
            "explain": "'Must have' + past participle expresses a confident deduction about the past."
          },
          {
            "q": "You ___ told me earlier — I could have helped.",
            "options": [
              "must have",
              "should have",
              "might have",
              "would have"
            ],
            "correct": 1,
            "explain": "'Should have' + past participle expresses criticism or regret about a past action."
          },
          {
            "q": "They ___ left already; the lights are off and the car is gone.",
            "options": [
              "might have",
              "must have",
              "should have",
              "would have"
            ],
            "correct": 1,
            "explain": "'Must have' expresses a strong, confident deduction based on evidence."
          },
          {
            "q": "He ___ passed the exam if he had studied harder.",
            "options": [
              "must have",
              "could have",
              "should have",
              "would have"
            ],
            "correct": 3,
            "explain": "'Would have' + past participle describes the unreal result of a hypothetical past condition."
          },
          {
            "q": "I ___ heard a noise, but I'm not certain — it might have been the wind.",
            "options": [
              "must have",
              "might have",
              "should have",
              "would have"
            ],
            "correct": 1,
            "explain": "'Might have' expresses a weaker, less certain possibility about the past."
          }
        ]
      },
      "conditionals_wishes": {
        "label": "Conditionals & Wishes",
        "when": "imagined situations, and wishes about the present or past",
        "questions": [
          {
            "q": "If it rains tomorrow, we ___ the picnic.",
            "options": [
              "cancel",
              "will cancel",
              "would cancel",
              "canceled"
            ],
            "correct": 1,
            "explain": "First conditional: if + present simple, will + base verb, for a likely future result."
          },
          {
            "q": "If I ___ rich, I would travel the world.",
            "options": [
              "am",
              "was",
              "were",
              "will be"
            ],
            "correct": 2,
            "explain": "Second conditional traditionally uses 'were' for all subjects in the if-clause."
          },
          {
            "q": "I wish I ___ more free time these days.",
            "options": [
              "have",
              "had",
              "will have",
              "having"
            ],
            "correct": 1,
            "explain": "'Wish' + past simple expresses a wish about the present."
          },
          {
            "q": "If only she ___ me the truth back then.",
            "options": [
              "told",
              "tells",
              "had told",
              "would tell"
            ],
            "correct": 2,
            "explain": "'If only' + past perfect expresses regret about the past."
          },
          {
            "q": "I wish you ___ so loudly — it's really distracting.",
            "options": [
              "wouldn't talk",
              "didn't talk",
              "hadn't talked",
              "won't talk"
            ],
            "correct": 0,
            "explain": "'Wish' + would is used to complain about an annoying present habit."
          }
        ]
      }
    }
  },
  "culture": {
